{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "options": {
    "typeAware": true,
    "maxWarnings": 0
  },
  "categories": {
    "correctness": "error",
    "suspicious": "off",
    "perf": "off"
  },
  "plugins": ["typescript", "import", "react", "react-hooks", "jsx-a11y", "unicorn", "oxc"],
  "env": {
    "es2024": true
  },
  "rules": {
    "no-debugger": "error",
    "no-console": "warn",
    "typescript/no-explicit-any": "warn",
    "react/react-in-jsx-scope": "off",
    "import/no-unassigned-import": "off",
    "unicorn/require-module-specifiers": "off"
  },
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.turbo/**",
    "**/.output/**",
    "**/.source/**",
    "**/routeTree.gen.ts"
  ]
}
